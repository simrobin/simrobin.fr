---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import { css } from '../../styled-system/css';
import profileImage from '../assets/images/profile.webp';
import Education from '../components/Education.astro';
import Experience from '../components/Experience.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';

const experiences = (await getCollection('experiences')).sort(
  (a, b) => a.data.order - b.data.order,
);
const educationEntries = (await getCollection('education')).sort(
  (a, b) => a.data.order - b.data.order,
);

const sectionStyle = css({
  padding: '6em 8%',
});

const sectionAltStyle = css({
  padding: '6em 8%',
  backgroundColor: 'bg.section',
});

const sectionWrapperStyle = css({
  margin: '0 auto',
  maxWidth: '1280px',
  width: '100%',
});

const sectionTitleStyle = css({
  display: 'flex',
  fontSize: '2em',
  marginBottom: '2rem',
  textTransform: 'uppercase',
});

const arrowTitleStyle = css({
  display: 'inline-block',
  verticalAlign: 'top',
  marginRight: '0.4rem',
  color: 'yellow',
});

/* About section */
const aboutWrapperStyle = css({
  margin: '0 auto',
  maxWidth: '1280px',
  width: '100%',
  position: 'relative',
});

const aboutContentStyle = css({
  md: {
    width: '50%',
  },
});

const aboutImageStyle = css({
  display: { base: 'none', md: 'block' },
  position: 'absolute',
  top: '0',
  right: '0',
  bottom: '0',
  width: '50%',
});

const aboutImageEl = css({
  width: '100%',
  height: '100%',
  objectFit: 'contain',
  objectPosition: 'right center',
});

const aboutTextStyle = css({
  fontSize: '1.4em',
  lineHeight: '1.4em',
});

const aboutSkillsStyle = css({
  fontSize: '1.4em',
  marginTop: '4em',
});

const skillItemStyle = css({
  '& + &': {
    marginTop: '0.5em',
  },
});

/* Experiences section */
const experiencesContainerStyle = css({
  lg: {
    display: 'flex',
  },
});

/* Education section */
const educationSectionWrapperStyle = css({
  margin: '0 auto',
  maxWidth: '1280px',
  width: '100%',
  md: {
    display: 'flex',
    justifyContent: 'space-between',
  },
});

const educationWrapperStyle = css({
  md: {
    flexBasis: '40%',
  },
  lg: {
    flexBasis: '55%',
  },
});

const educationsContainerStyle = css({
  lg: {
    display: 'flex',
  },
});

const resumeStyle = css({
  alignContent: 'center',
  backgroundColor: 'yellow',
  display: 'flex',
  flexWrap: 'wrap',
  justifyContent: 'center',
  padding: '4rem 2rem',
  textAlign: 'center',
  marginTop: { base: '2rem', md: '0' },
  md: {
    flexBasis: '60%',
  },
  lg: {
    flexBasis: '35%',
  },
  '& > *': {
    flexBasis: '100%',
  },
});

const resumeIconStyle = css({
  display: 'inline-block',
  color: 'gray',
});

const resumeDescriptionStyle = css({
  fontSize: '1.4em',
  marginTop: '1rem',
  color: 'gray',
});

const resumeLinkStyle = css({
  backgroundColor: 'white',
  color: 'gray',
  display: 'inline-block',
  flexBasis: 'auto!',
  fontSize: '1.6em',
  marginTop: '1.5rem',
  padding: '1rem 2rem',
  textDecoration: 'none',
  textTransform: 'uppercase',
});

/* Interests section */
const interestsContainerStyle = css({
  display: 'flex',
  flexWrap: 'wrap',
  justifyContent: 'space-between',
  marginTop: '4em',
  gap: '3em 0',
});

const interestStyle = css({
  textAlign: 'center',
  flexBasis: { base: '50%', sm: '33.333%', md: 'auto' },
});

const interestIconStyle = css({
  display: 'inline-block',
  color: 'yellow',
});

const interestNameStyle = css({
  fontSize: '1.4em',
  marginTop: '1em',
  textTransform: 'uppercase',
});

const interests = [
  { icon: 'bicycle', name: 'Vélo' },
  { icon: 'roller', name: 'Roller' },
  { icon: 'tennis', name: 'Tennis' },
  { icon: 'cooking', name: 'Cuisine' },
  { icon: 'music', name: 'Guitare' },
  { icon: 'map', name: 'Voyage' },
];
---

<Layout
  title="Simon Robin"
  description="Simon Robin, Développeur Front-end sur Paris"
>
  <Header />

  <main>
    <section class={sectionStyle}>
      <div class={aboutWrapperStyle}>
        <div class={aboutContentStyle}>
          <h2 class={sectionTitleStyle}>
            <Icon name="arrow" size={22} class={arrowTitleStyle} />
            <span>À propos de moi</span>
          </h2>

          <p class={aboutTextStyle}>
            Passionné de développement, j'aime découvrir et construire des
            applications web qui facilitent le quotidien des utilisateurs.
            <br /> Je profite de la communauté open source et du travail en équipe
            autour de projets communs pour maintenir mes connaissances à jour au
            quotidien.
          </p>

          <ul class={aboutSkillsStyle}>
            <li class={skillItemStyle}>
              <strong>Web</strong> : HTML, CSS, JavaScript, Angular(JS), React
            </li>
            <li class={skillItemStyle}>
              <strong>Backend</strong> : Golang, Node.js, SQL, PHP
            </li>
            <li class={skillItemStyle}>
              <strong>Devops</strong> : Docker, Kubernetes, Bash, Jenkins, Travis
            </li>
            <li class={skillItemStyle}>
              <strong>Langues</strong> : Anglais (courant), Allemand (scolaire)
            </li>
          </ul>
        </div>

        <div class={aboutImageStyle}>
          <Image
            src={profileImage}
            alt="Simon Robin"
            class={aboutImageEl}
            loading="eager"
          />
        </div>
      </div>
    </section>

    <section class={sectionAltStyle}>
      <div class={sectionWrapperStyle}>
        <h2 class={sectionTitleStyle}>Expériences</h2>

        <div class={experiencesContainerStyle}>
          {
            experiences.map((exp, i) => (
              <Experience
                startDate={exp.data.startDate}
                endDate={exp.data.endDate}
                title={exp.data.title}
                location={exp.data.location}
                missions={exp.data.missions}
                isFirst={i === 0}
              />
            ))
          }
        </div>
      </div>
    </section>

    <section class={sectionStyle}>
      <div class={educationSectionWrapperStyle}>
        <div class={educationWrapperStyle}>
          <h2 class={sectionTitleStyle}>Formations</h2>

          <div class={educationsContainerStyle}>
            {
              educationEntries.map((edu, i) => (
                <Education
                  startDate={edu.data.startDate}
                  endDate={edu.data.endDate}
                  title={edu.data.title}
                  location={edu.data.location}
                  isFirst={i === 0}
                />
              ))
            }
          </div>
        </div>

        <div class={resumeStyle}>
          <Icon name="file" size={44} class={resumeIconStyle} />
          <div class={resumeDescriptionStyle}>
            Besoin d&#39;une version transportable ?
          </div>
          <a
            href="/files/cv-simon-robin.pdf"
            target="_blank"
            title="Télécharger mon CV"
            class={resumeLinkStyle}
          >
            Télécharger mon CV
          </a>
        </div>
      </div>
    </section>

    <section class={sectionAltStyle}>
      <div class={sectionWrapperStyle}>
        <h2 class={sectionTitleStyle}>Centres d&#39;intérêts</h2>

        <ul class={interestsContainerStyle}>
          {
            interests.map((interest) => (
              <li class={interestStyle}>
                <Icon
                  name={interest.icon}
                  size={44}
                  class={interestIconStyle}
                />
                <p class={interestNameStyle}>{interest.name}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
