{
  "name": "about",
  "version": "3.0.0",
  "description": "Personal website",
  "author": "Simon Robin",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simrobin/about.git"
  },
  "homepage": "https://simrobin.fr",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": "=22",
    "pnpm": "=10"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "biome check --fix src/",
    "lint:file": "biome check --fix",
    "format": "biome format --write src/",
    "test": "playwright test",
    "test:ci": "playwright test",
    "test:update": "playwright test --update-snapshots",
    "typecheck": "astro check",
    "prepare": "panda codegen --clean"
  },
  "dependencies": {
    "@fontsource-variable/montserrat": "^5.2.8",
    "astro": "^6.1.6",
    "astro-icon": "^1.1.5",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@biomejs/biome": "2.4.10",
    "@iconify-json/lucide": "^1.2.100",
    "@iconify-json/simple-icons": "^1.2.75",
    "@pandacss/dev": "^1.9.1",
    "@pandacss/postcss": "^1.9.1",
    "@playwright/test": "1.58.2",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"],
    "overrides": {
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "yaml@>=2.0.0 <2.8.3": "2.8.3",
      "tar": ">=7.5.11",
      "undici": ">=7.24.0"
    }
  },
  "license": "ISC"
}
